# Gemini API Key (for local development)
# 取得先: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# GitHub Personal Access Token (for workflow_dispatch trigger)
# Scopes needed: workflow
VITE_GITHUB_TOKEN=

# X (Twitter) API Keys - for local reference only
# These should be set as GitHub Secrets for the Actions workflow
VITE_X_CONSUMER_KEY=
VITE_X_CONSUMER_SECRET=
VITE_X_ACCESS_TOKEN=
VITE_X_ACCESS_TOKEN_SECRET=
